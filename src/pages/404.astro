---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="container" style="text-align: center; padding-block: var(--space-24);">
    <h1 style="font-size: var(--text-2xl); margin-bottom: var(--space-4);">404</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-8);">This page doesn't exist.</p>
    <a href="/" class="btn btn-primary">Go home</a>
  </div>
</BaseLayout>
