---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/pages/resources.css';

// ── GitHub repos: fetched at build time ─────────────────────────────
interface GhRepo {
  slug: string;       // owner/repo
  name: string;
  description: string;
  link: string;
}

const codeRepos: GhRepo[] = [
  {
    slug: 'williamsdrake/oralAtlas',
    name: 'Oral Atlas (2021)',
    description: 'Code used to analyze datasets and generate figures from Williams et al., 2021',
    link: 'https://github.com/williamsdrake/oralAtlas',
  },
  {
    slug: 'williamsdrake/epithelial-IL23',
    name: 'Kim et al. (2024)',
    description: 'Code used to analyze CZI datasets and generate figures in Kim et al., 2024',
    link: 'https://github.com/williamsdrake/epithelial-IL23',
  },
  {
    slug: 'dwilliamsLab/gingiva-2025',
    name: 'Theofilou et al. (2026)',
    description: 'Code used to analyze datasets and generate figures in Theofilou et al., 2026',
    link: 'https://github.com/dwilliamsLab/gingiva-2025',
  },
];

const moreRepos: GhRepo[] = [
  {
    slug: 'greenelab/lab-website-template',
    name: 'Lab website template',
    description: 'An incredible template from Greene Lab used to make this website. Fork it on GitHub for your own use!',
    link: 'https://github.com/greenelab/lab-website-template',
  },
];

async function fetchRepoData(slug: string) {
  try {
    const res = await fetch(`https://api.github.com/repos/${slug}`, {
      headers: { Accept: 'application/vnd.github+json' },
    });
    if (!res.ok) return null;
    const data = await res.json();
    return {
      stars: data.stargazers_count as number,
      forks: data.forks_count as number,
      language: data.language as string | null,
      updatedAt: data.pushed_at as string,
    };
  } catch {
    return null;
  }
}

const codeWithStats = await Promise.all(
  codeRepos.map(async r => ({ ...r, stats: await fetchRepoData(r.slug) }))
);

const moreRepoWithStats = await Promise.all(
  moreRepos.map(async r => ({ ...r, stats: await fetchRepoData(r.slug) }))
);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}

function formatNum(n: number) {
  return n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
}

// ── Static resources ─────────────────────────────────────────────────
const datasets = [
  {
    name: 'Oral Atlas (2021)',
    description: 'An interactive data viewer for datasets from Williams et al., 2021',
    link: 'https://oral.cellatlas.io/',
    image: '/images/resource/atlas.jpg',
  },
  {
    name: 'Theofilou et al. (2026)',
    description: 'Raw and processed data from Theofilou et al., 2026',
    link: 'https://dataverse.harvard.edu/dataverse/gingiva2025',
    image: '/images/resource/dataverse.png',
  },
];

const protocols = [
  {
    name: 'Oral mucosa dissociation',
    description: 'A detailed method to dissociate oral mucosal tissues into single cell suspensions',
    link: 'https://doi.org/10.1016/j.xpro.2021.100908',
    image: '/images/resource/dissociation.jpg',
  },
];

const moreStatic = [
  {
    name: 'R for Data Science',
    description: 'Useful introduction to R programming language for scientists.',
    link: 'https://r4ds.had.co.nz/index.html',
    image: '/images/resource/r.jpg',
    stats: null,
  },
  {
    name: 'Adobe Illustrator Guide',
    description: 'Fantastic guide to using Adobe Illustrator for scientific work from Raj Lab',
    link: 'http://rajlaboratory.blogspot.com/2019/08/i-adobe-illustrator-for-scientific.html',
    image: '/images/resource/ai.jpg',
    stats: null,
  },
  {
    name: 'Academic CV',
    description: 'A read-only version of my academic CV made in LaTeX from the Awesome-CV template. Download to create your own.',
    link: 'https://www.overleaf.com/read/gptprjgkgzvq',
    image: '/images/resource/overleaf.jpg',
    stats: null,
  },
];

const more = [
  ...moreStatic,
  ...moreRepoWithStats.map(r => ({ ...r, image: null })),
];

const tabs = [
  { id: 'code',      label: 'Code',      count: codeWithStats.length },
  { id: 'datasets',  label: 'Datasets',  count: datasets.length },
  { id: 'protocols', label: 'Protocols', count: protocols.length },
  { id: 'more',      label: 'More',      count: more.length },
];
---

<BaseLayout title="Resources" description="Datasets, code, protocols, and tools from the Laboratory of Oral Mucosal Immunity.">
  <div class="container">
    <div class="page-header page-header--narrow">
      <h1>Resources</h1>
      <p>Datasets, code, protocols, and tools from our lab and beyond.</p>
    </div>

    <section class="section section--sm">

      <!-- Tab bar -->
      <div class="resource-tabs" role="tablist" aria-label="Resource categories">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            class="resource-tab"
            data-tab={tab.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${tab.id}`}
            id={`tab-${tab.id}`}
          >
            {tab.label}
            <span class="resource-tab-count">{tab.count}</span>
          </button>
        ))}
      </div>

      <!-- Code panel -->
      <div role="tabpanel" id="panel-code" aria-labelledby="tab-code" class="resource-panel">
        <ul role="list" class="resource-grid">
          {codeWithStats.map(item => (
            <li>
              <a href={item.link} class="resource-card resource-card--repo" target="_blank" rel="noopener noreferrer">
                <div class="repo-card-header">
                  <svg class="repo-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="16" height="16">
                    <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
                  </svg>
                  <span class="repo-slug">{item.slug}</span>
                </div>
                <div class="repo-card-body">
                  <span class="resource-card-name">{item.name}</span>
                  <span class="resource-card-desc">{item.description}</span>
                </div>
                {item.stats && (
                  <div class="repo-card-footer">
                    {item.stats.language && (
                      <span class="repo-stat">
                        <span class="repo-lang-dot" aria-hidden="true"></span>
                        {item.stats.language}
                      </span>
                    )}
                    <span class="repo-stat">
                      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
                        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
                      </svg>
                      {formatNum(item.stats.stars)}
                    </span>
                    <span class="repo-stat">
                      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
                        <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
                      </svg>
                      {formatNum(item.stats.forks)}
                    </span>
                    <span class="repo-stat repo-stat--date">Updated {formatDate(item.stats.updatedAt)}</span>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Datasets panel -->
      <div role="tabpanel" id="panel-datasets" aria-labelledby="tab-datasets" class="resource-panel" hidden>
        <ul role="list" class="resource-grid">
          {datasets.map(item => (
            <li>
              <a href={item.link} class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-card-image">
                  <img src={item.image} alt={item.name} loading="lazy" width="640" height="360" />
                </div>
                <div class="resource-card-body">
                  <span class="resource-card-name">{item.name}</span>
                  <span class="resource-card-desc">{item.description}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Protocols panel -->
      <div role="tabpanel" id="panel-protocols" aria-labelledby="tab-protocols" class="resource-panel" hidden>
        <ul role="list" class="resource-grid">
          {protocols.map(item => (
            <li>
              <a href={item.link} class="resource-card" target="_blank" rel="noopener noreferrer">
                <div class="resource-card-image">
                  <img src={item.image} alt={item.name} loading="lazy" width="640" height="360" />
                </div>
                <div class="resource-card-body">
                  <span class="resource-card-name">{item.name}</span>
                  <span class="resource-card-desc">{item.description}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More panel -->
      <div role="tabpanel" id="panel-more" aria-labelledby="tab-more" class="resource-panel" hidden>
        <ul role="list" class="resource-grid">
          {more.map(item => (
            <li>
              <a href={item.link} class="resource-card" class:list={[{ 'resource-card--repo': !item.image }]} target="_blank" rel="noopener noreferrer">
                {'image' in item && item.image ? (
                  <div class="resource-card-image">
                    <img src={item.image} alt={item.name} loading="lazy" width="640" height="360" />
                  </div>
                ) : (
                  <div class="repo-card-header">
                    <svg class="repo-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="16" height="16">
                      <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
                    </svg>
                    <span class="repo-slug">{'slug' in item ? item.slug : ''}</span>
                  </div>
                )}
                <div class="repo-card-body">
                  <span class="resource-card-name">{item.name}</span>
                  <span class="resource-card-desc">{item.description}</span>
                </div>
                {'stats' in item && item.stats && (
                  <div class="repo-card-footer">
                    {item.stats.language && (
                      <span class="repo-stat">
                        <span class="repo-lang-dot" aria-hidden="true"></span>
                        {item.stats.language}
                      </span>
                    )}
                    <span class="repo-stat">
                      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
                        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
                      </svg>
                      {formatNum(item.stats.stars)}
                    </span>
                    <span class="repo-stat">
                      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
                        <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
                      </svg>
                      {formatNum(item.stats.forks)}
                    </span>
                    <span class="repo-stat repo-stat--date">Updated {formatDate(item.stats.updatedAt)}</span>
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </section>
  </div>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

  function activate(tab: HTMLButtonElement) {
    tabs.forEach(t => t.setAttribute('aria-selected', 'false'));
    panels.forEach(p => { p.hidden = true; });
    tab.setAttribute('aria-selected', 'true');
    const target = document.getElementById(`panel-${tab.dataset.tab}`);
    if (target) target.hidden = false;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => activate(tab));
    tab.addEventListener('keydown', (e: KeyboardEvent) => {
      const list = Array.from(tabs);
      const idx = list.indexOf(tab);
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        const next = list[(idx + 1) % list.length];
        activate(next); next.focus();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        const prev = list[(idx - 1 + list.length) % list.length];
        activate(prev); prev.focus();
      }
    });
  });
</script>
