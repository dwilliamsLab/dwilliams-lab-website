---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Laboratory of Oral Mucosal Immunity"
  description="We investigate how local tissue organization and microbial exposure shape adaptive immunity, wound healing, and whole-body physiology at the oral barrier."
>
  <!-- Hero -->
  <section class="hero section">
    <div class="container">
      <h1 class="hero-headline">
        Decoding how the oral barrier senses, heals, and signals
      </h1>
      <p class="hero-body">
        The mouth is a densely colonized barrier that must distinguish friend from foe,
        repair constant injury, and relay information to distant tissues. Our lab investigates
        how local tissue organization and microbial exposure shape adaptive immunity,
        wound healing, and whole‑body physiology at this interface.
      </p>
      <a href="/research" class="btn btn-primary">Read more about our research</a>
    </div>
  </section>

  <!-- Lab News -->
  <section class="section section--sm">
    <div class="container">
      <h2 class="section-heading">Lab News</h2>
      {posts.length === 0 ? (
        <p style="color: var(--color-text-muted)">No posts yet.</p>
      ) : (
        <ul role="list" class="post-list">
          {posts.map(post => (
            <li class="post-item">
              <a href={`/news/${post.slug}`} class="post-link">
                <span class="post-title">{post.data.title}</span>
                <time class="post-date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(var(--space-16), 10vw, var(--space-24));
    border-bottom: 1px solid var(--color-divider);
  }

  .hero-headline {
    font-size: var(--text-2xl);
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    max-width: 16ch;
    margin-bottom: var(--space-6);
    line-height: 1.2;
  }

  .hero-body {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
  }
  .btn-primary {
    background: var(--color-primary);
    color: white;
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  .section-heading {
    font-size: var(--text-xl);
    margin-bottom: var(--space-8);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-text);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-divider);
    transition: color var(--transition);
  }
  .post-link:hover { color: var(--color-primary); }
  .post-title { font-weight: 500; }
  .post-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
  }
</style>
