---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/pages/home.css';
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Laboratory of Oral Mucosal Immunity"
  description="We investigate how local tissue organization and microbial exposure shape adaptive immunity, wound healing, and whole-body physiology at the oral barrier."
>
  <!-- Hero -->
  <section class="hero section">
    <div class="container">
      <h1 class="hero-headline">
        Decoding how the oral barrier signals, senses, and heals
      </h1>
      <p class="hero-body">
        The mouth is a densely colonized barrier that must distinguish friend from foe,
        repair constant injury, and relay information to distant tissues. Our lab investigates
        how local tissue organization and microbial exposure shape adaptive immunity,
        wound healing, and whole‑body physiology at this interface.
      </p>
      <a href="/research" class="btn btn-primary">Read more about our research</a>
    </div>
  </section>

  <!-- Lab News -->
  <section class="section section--sm">
    <div class="container">
      <h2 class="section-heading">Lab News</h2>
      {posts.length === 0 ? (
        <p style="color: var(--color-text-muted)">No posts yet.</p>
      ) : (
        <ul role="list" class="post-list">
          {posts.map(async (post) => {
            const { Content } = await render(post);
            const prettyDate = post.data.date.toLocaleDateString('en-US', {
              year: 'numeric', month: 'long', day: 'numeric'
            });
            return (
              <li>
                <button
                  class="post-card"
                  type="button"
                  aria-haspopup="dialog"
                >
                  {post.data.image && (
                    <div class="post-card-thumb">
                      <img
                        src={'/' + post.data.image}
                        alt={post.data.title}
                        width="64"
                        height="64"
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="post-card-body">
                    <span class="post-title">{post.data.title}</span>
                    <time class="post-date" datetime={post.data.date.toISOString()}>
                      {prettyDate}
                    </time>
                  </div>
                </button>

                <dialog class="post-dialog" aria-labelledby={'post-title-' + post.id}>
                  <div class="post-dialog-card">
                    <button
                      class="post-dialog-close"
                      type="button"
                      data-dialog-close
                      aria-label={'Close post: ' + post.data.title}
                    >
                      ×
                    </button>

                    {post.data.image && (
                      <div class="post-dialog-image">
                        <img
                          src={'/' + post.data.image}
                          alt={post.data.title}
                          width="480"
                          height="320"
                          loading="eager"
                        />
                      </div>
                    )}

                    <h2 id={'post-title-' + post.id} class="post-dialog-title">
                      {post.data.title}
                    </h2>
                    <time class="post-dialog-date" datetime={post.data.date.toISOString()}>
                      {prettyDate}
                    </time>

                    <div class="post-dialog-body prose">
                      <Content />
                    </div>
                  </div>
                </dialog>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  <script is:inline>
    const postCards = document.querySelectorAll('.post-card');
    const postDialogs = document.querySelectorAll('.post-dialog');

    postCards.forEach((card) => {
      card.addEventListener('click', () => {
        const parent = card.closest('li');
        const dialog = parent?.querySelector('.post-dialog');
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
        }
      });
    });

    postDialogs.forEach((dialog) => {
      const closeButton = dialog.querySelector('[data-dialog-close]');
      closeButton?.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (event) => {
        const card = dialog.querySelector('.post-dialog-card');
        if (!card) return;
        const rect = card.getBoundingClientRect();
        const clickedInside =
          event.clientX >= rect.left &&
          event.clientX <= rect.right &&
          event.clientY >= rect.top &&
          event.clientY <= rect.bottom;
        if (!clickedInside) dialog.close();
      });
    });
  </script>
</BaseLayout>
