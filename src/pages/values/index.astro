---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/pages/values.css';
---

<BaseLayout title="Values" description="The values and expectations of the Laboratory of Oral Mucosal Immunity.">
  <div class="container">

    <!-- Page header -->
    <div class="page-header page-header--narrow">
      <h1>Values</h1>
      <p>In the Laboratory of Oral Mucosal Immunity, we believe that science is for <b>everybody</b>.</p>
    </div>

    <!-- Diversity & Inclusion -->
    <section class="section section--sm">
      <h2 class="values-section-heading">Diversity &amp; Inclusion</h2>
      <div class="values-grid">
        <div class="values-card">
          <h3 class="values-card-title">Belonging</h3>
          <p>We foster a research environment that values belonging. We welcome individuals of all backgrounds, regardless of race, ethnicity, nationality, gender identity, physical abilities, or any other identity.</p>
        </div>
        <div class="values-card">
          <h3 class="values-card-title">Opposing Discrimination</h3>
          <p>We actively oppose discrimination of any kind, including racism, sexism, homophobia, ableism, transphobia, and xenophobia.</p>
        </div>
        <div class="values-card">
          <h3 class="values-card-title">Safe Space</h3>
          <p>We strive to create a safe and inclusive space for anyone passionate about science and eager to learn.</p>
        </div>
      </div>
    </section>

    <!-- Scientific Integrity -->
    <section class="section section--sm">
      <h2 class="values-section-heading">Scientific Integrity</h2>
      <div class="values-grid">
        <div class="values-card">
          <h3 class="values-card-title">Honesty &amp; Rigor</h3>
          <p>We are committed to scientific discovery guided by honesty, integrity, and rigor.</p>
        </div>
        <div class="values-card">
          <h3 class="values-card-title">Collaboration</h3>
          <p>We believe in the power of collaboration and strive for open communication within the lab.</p>
        </div>
        <div class="values-card">
          <h3 class="values-card-title">Open Science</h3>
          <p>We prioritize open access to our research, citation of previous discoveries, and transparency throughout the research process.</p>
        </div>
      </div>
    </section>

    <!-- Expectations -->
    <section class="section section--sm">
      <h2 class="values-section-heading">Expectations</h2>
      <div class="expectations-grid">
        <div class="expectations-col">
          <h3 class="expectations-heading">What you can expect from Drake</h3>
          <p class="expectations-intro">Drake&rsquo;s goal as a mentor is to guide each trainee to achieve their goals and challenge each mentee to expand their own vision of success. As a member of LOMI, you can expect:</p>
          <ul class="expectations-list">
            <li>Respect and compassion</li>
            <li>Open lines of communication</li>
            <li>Individualized mentoring and training plans</li>
            <li>Hands-on training in science, writing, and communication</li>
            <li>Networking opportunities</li>
          </ul>
          <a
            href="https://drive.google.com/file/d/1m_Zdccti31sFteLnZu5J7dZ5ogwH8fsH/view"
            class="expectations-statement-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" width="14" height="14">
              <path d="M2 1.75C2 .784 2.784 0 3.75 0h6.586c.464 0 .909.184 1.237.513l2.914 2.914c.329.328.513.773.513 1.237v9.586A1.75 1.75 0 0 1 13.25 16h-9.5A1.75 1.75 0 0 1 2 14.25Zm1.75-.25a.25.25 0 0 0-.25.25v12.5c0 .138.112.25.25.25h9.5a.25.25 0 0 0 .25-.25V6h-2.75A1.75 1.75 0 0 1 9 4.25V1.5Zm6.75.062V4.25c0 .138.112.25.25.25h2.688l-.011-.013-2.914-2.914-.013-.011Z"/>
            </svg>
            PhD advising statement
          </a>
        </div>
        <div class="expectations-col">
          <h3 class="expectations-heading">What we expect from you</h3>
          <p class="expectations-intro">We welcome individuals from all walks of life and at any career stage. If you are interested in learning more about barrier immunity in the context of the oral mucosa, we expect:</p>
          <ul class="expectations-list">
            <li>Respect and compassion</li>
            <li>Open lines of communication</li>
            <li>Passion and curiosity</li>
            <li>Careful and thoughtful work</li>
            <li>Commitment to personal and professional growth</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Support -->
    <section class="section section--sm">
      <div class="support-block">
        <p class="support-message">Science (and life) can be tough - but you are not alone.</p>
        <div class="support-links">
          <a
            href="https://hr.umn.edu/Benefits/Mental-Health-Resources"
            class="support-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="support-link-label">Mental health resources</span>
            <span class="support-link-sub">University of Minnesota HR</span>
          </a>
          <a
            href="https://recwell.umn.edu/wellbeing"
            class="support-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="support-link-label">Wellbeing resources</span>
            <span class="support-link-sub">UMN Recreation &amp; Wellness</span>
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
