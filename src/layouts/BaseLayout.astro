---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Laboratory of Oral Mucosal Immunity',
  description = 'Website for the Laboratory of Oral Mucosal Immunity at the University of Minnesota',
  ogImage = '/images/share.png',
} = Astro.props;

const siteName = 'Laboratory of Oral Mucosal Immunity';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, 'https://williams.science').toString();
const ogImageURL = new URL(ogImage, 'https://williams.science').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-VETJQ1T7RM">
    </script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VETJQ1T7RM');
    </script>

    <!-- Fonts: Instrument Serif (display) + Work Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@300..700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <script
      async
      src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"
    ></script>

    <script
      async
      src="https://badge.dimensions.ai/badge.js"
      charset="utf-8"
    ></script>

    <!-- Splash overlay styles -->
    <style>
      #splash {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background-color: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          opacity 1.2s ease,
          backdrop-filter 1.2s ease,
          background-color 1.2s ease;
      }

      #splash.hidden {
        opacity: 0;
        pointer-events: none;
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        background-color: rgba(255, 255, 255, 0);
      }

      #splash-logo {
        width: min(500px, 80vw);
      }
    </style>
  </head>
  <body>
    <!-- One-time animated splash overlay -->
    <div id="splash">
      <div id="splash-logo">
        <svg width="100%" height="100%" viewBox="0 0 500 200" version="1.1"
             xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
             xml:space="preserve" xmlns:serif="http://www.serif.com/"
             style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;">
          <defs>
            <style type="text/css"><![CDATA[
              /* ---- ICON ANIMATION (unchanged) ---- */

              #n2-ring circle {
                animation-name: n2Stroke;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              #n2-fill circle {
                animation-name: n2Fill;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              @keyframes n2Stroke {
                0%   { stroke: rgb(156,163,175); }
                18%  { stroke: rgb(156,163,175); }
                28%  { stroke: rgb(15,118,110); }
                100% { stroke: rgb(15,118,110); }
              }
              @keyframes n2Fill {
                0%   { fill: rgb(156,163,175); }
                18%  { fill: rgb(156,163,175); }
                28%  { fill: rgb(15,118,110); }
                100% { fill: rgb(15,118,110); }
              }

              #n3-ring circle {
                animation-name: n3Stroke;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              #n3-fill circle {
                animation-name: n3Fill;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              @keyframes n3Stroke {
                0%   { stroke: rgb(156,163,175); }
                44%  { stroke: rgb(156,163,175); }
                52%  { stroke: rgb(15,118,110); }
                100% { stroke: rgb(15,118,110); }
              }
              @keyframes n3Fill {
                0%   { fill: rgb(156,163,175); }
                44%  { fill: rgb(156,163,175); }
                52%  { fill: rgb(15,118,110); }
                100% { fill: rgb(15,118,110); }
              }

              #center-ring circle {
                animation-name: centerStroke;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              #center-fill circle {
                animation-name: centerFill;
                animation-duration: 5s;
                animation-timing-function: ease-in-out;
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              @keyframes centerStroke {
                0%   { stroke: rgb(156,163,175); }
                70%  { stroke: rgb(156,163,175); }
                90%  { stroke: rgb(15,118,110); }
                100% { stroke: rgb(15,118,110); }
              }
              @keyframes centerFill {
                0%   { fill: rgb(156,163,175); }
                70%  { fill: rgb(156,163,175); }
                90%  { fill: rgb(15,118,110); }
                100% { fill: rgb(15,118,110); }
              }

              /* ---- LETTER FADE-IN (applies to path groups) ---- */

              #label-L, #label-MI {
                opacity: 0;
                animation-name: labelFade;
                animation-duration: 1s;
                animation-timing-function: ease-in-out;
                animation-delay: 3.5s;  /* 70% of 5s: when center cell starts changing */
                animation-iteration-count: 1;
                animation-fill-mode: forwards;
              }
              @keyframes labelFade {
                0%   { opacity: 0; }
                100% { opacity: 1; }
              }
            ]]></style>
          </defs>

          <!-- Icon group transformed exactly as in your Affinity export -->
          <g transform="matrix(1,0,0,1,150,0)">

            <!-- Arc 1 grey base -->
            <g id="arc2-base" transform="matrix(1.71104,1.03826,-0.777585,1.28144,-2.337378,3.09829)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(156,163,175);stroke-width:3px;"/>
            </g>
            <!-- Arc 1 teal overlay, animated (26–44%) -->
            <g transform="matrix(1.71104,1.03826,-0.777585,1.28144,-2.337378,3.09829)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:3px;stroke-dasharray:70,70;stroke-dashoffset:70;">
                <animate attributeName="stroke-dashoffset"
                         values="70;70;0;0;0"
                         keyTimes="0;0.26;0.44;0.44;1"
                         dur="5s" repeatCount="1" fill="freeze"/>
              </path>
            </g>

            <!-- Arc 2 grey base -->
            <g id="arc2-base1" serif:id="arc2-base"
               transform="matrix(-0.032809,-2.00114,1.49871,-0.024571,24.905522,207.66547)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(156,163,175);stroke-width:3px;"/>
            </g>
            <!-- Arc 2 teal overlay, animated (0–18%) -->
            <g transform="matrix(-0.032809,-2.00114,1.49871,-0.024571,24.905522,207.66547)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:3px;stroke-dasharray:70,70;stroke-dashoffset:70;">
                <animate attributeName="stroke-dashoffset"
                         values="70;70;0;0;0"
                         keyTimes="0;0;0.18;0.18;1"
                         dur="5s" repeatCount="1" fill="freeze"/>
              </path>
            </g>

            <!-- Arc 3 grey base -->
            <g id="arc2-base2" serif:id="arc2-base"
               transform="matrix(-1.77502,0.924632,-0.692483,-1.32936,178.834322,86.08597)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(156,163,175);stroke-width:3px;"/>
            </g>
            <!-- Arc 3 teal overlay, animated (52–70%) -->
            <g transform="matrix(-1.77502,0.924632,-0.692483,-1.32936,178.834322,86.08597)">
              <path d="M72,68C66.949,72.263 60.549,74.603 53.94,74.603C45.397,74.603 37.308,70.694 32,64"
                    style="fill:none;fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:3px;stroke-dasharray:70,70;stroke-dashoffset:70;">
                <animate attributeName="stroke-dashoffset"
                         values="70;70;0;0;0"
                         keyTimes="0;0.52;0.70;0.70;1"
                         dur="5s" repeatCount="1" fill="freeze"/>
              </path>
            </g>

            <!-- Center cell ring and nucleus -->
            <g id="center-ring" transform="matrix(1.68102,1.0836,-1.0836,1.68102,37.062222,-41.69653)">
              <circle cx="50" cy="50" r="20"
                      style="fill:none;stroke:rgb(156,163,175);stroke-width:3px;stroke-linecap:butt;"/>
            </g>
            <g id="center-fill" transform="matrix(1.35217,0.871619,-0.871619,1.35217,49.556122,-3.189419)">
              <circle cx="50" cy="50" r="10" style="fill:rgb(156,163,175);"/>
            </g>

            <!-- n1 always teal -->
            <g id="n1-ring" transform="matrix(1.68102,1.0836,-1.0836,1.68102,16.339322,-83.37683)">
              <circle cx="70" cy="28" r="7"
                      style="fill:none;stroke:rgb(15,118,110);stroke-width:8px;stroke-linecap:butt;"
                      vector-effect="non-scaling-stroke"/>
            </g>
            <g id="n1-fill" transform="matrix(1.68102,1.0836,-1.0836,1.68102,16.339322,-83.37683)">
              <circle cx="70" cy="28" r="3" style="fill:rgb(15,118,110);"/>
            </g>

            <!-- n2 -->
            <g transform="matrix(0.840509,0.541798,-0.541798,0.840509,52.916922,-40.27693)">
              <g id="n2-ring" transform="matrix(2,0,0,2,0,10)">
                <circle cx="72" cy="68" r="7"
                        style="fill:none;stroke:rgb(156,163,175);stroke-width:8px;stroke-linecap:butt;"
                        vector-effect="non-scaling-stroke"/>
              </g>
              <g id="n2-fill" transform="matrix(2,0,0,2,0,10)">
                <circle cx="72" cy="68" r="3" style="fill:rgb(156,163,175);"/>
              </g>
            </g>

            <!-- n3 -->
            <g id="n3-ring" transform="matrix(1.68102,1.0836,-1.0836,1.68102,2.318922,-26.96443)">
              <circle cx="30" cy="52" r="7"
                      style="fill:none;stroke:rgb(156,163,175);stroke-width:8px;stroke-linecap:butt;"
                      vector-effect="non-scaling-stroke"/>
            </g>
            <g id="n3-fill" transform="matrix(1.68102,1.0836,-1.0836,1.68102,2.318922,-26.96443)">
              <circle cx="30" cy="52" r="3" style="fill:rgb(156,163,175);"/>
            </g>

          </g><!-- end icon group -->

          <!-- Letters as paths, with positions/kerning exactly from Affinity export -->

          <!-- L -->
          <g id="label-L" transform="matrix(6.984993,0,0,6.984993,32.942658,136.534384)">
            <path d="M1.172,0L1.172,-11.453L2.688,-11.453L2.688,-1.352L8.328,-1.352L8.328,0L1.172,0Z"
                  style="fill:rgb(15,118,110);fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:0.68px;stroke-linejoin:round;stroke-miterlimit:2;"/>
          </g>

          <!-- MI -->
          <g id="label-MI">
            <g transform="matrix(6.984993,0,0,6.984993,320.098724,136.79847)">
              <path d="M1.188,0L1.188,-11.453L3.469,-11.453L6.18,-3.344C6.43,-2.589 6.612,-2.023 6.727,-1.648C6.857,-2.065 7.06,-2.677 7.336,-3.484L10.078,-11.453L12.117,-11.453L12.117,0L10.656,0L10.656,-9.586L7.328,0L5.961,0L2.648,-9.75L2.648,0L1.188,0Z"
                    style="fill:rgb(15,118,110);fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:0.68px;stroke-linejoin:round;stroke-miterlimit:2;"/>
            </g>
            <g transform="matrix(6.984993,0,0,6.984993,344.765391,136.79847)">
              <rect x="14.82" y="-11.453" width="1.516" height="11.453"
                    style="fill:rgb(15,118,110);fill-rule:nonzero;stroke:rgb(15,118,110);stroke-width:0.68px;stroke-linejoin:round;stroke-miterlimit:30;"/>
            </g>
          </g>

        </svg>
      </div>
    </div>

    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <nav class="nav-inner" aria-label="Main navigation">
        <a href="/" class="site-logo" aria-label="Laboratory of Oral Mucosal Immunity — home">
          <span class="logo-name">Laboratory of Oral Mucosal Immunity</span>
          <span class="logo-sub">at U of MN</span>
        </a>
        <ul role="list" class="nav-links">
          <li><a href="/research">Research</a></li>
          <li><a href="/team">Team</a></li>
          <li><a href="/publications">Publications</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/values">Values</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <button
          class="nav-toggle"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span></span><span></span><span></span>
        </button>
      </nav>
      <div id="mobile-nav" class="mobile-nav" hidden>
        <ul role="list">
          <li><a href="/research">Research</a></li>
          <li><a href="/team">Team</a></li>
          <li><a href="/publications">Publications</a></li>
          <li><a href="/events">Events</a></li>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/values">Values</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p>&copy; {new Date().getFullYear()} Laboratory of Oral Mucosal Immunity</p>
        <div class="footer-links">
          <a href="mailto:drakew@umn.edu" aria-label="Email">Email</a>
          <a href="https://github.com/dwilliamslab" aria-label="GitHub" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const toggle = document.querySelector('.nav-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      if (toggle && mobileNav) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          mobileNav.hidden = expanded;
        });
      }
    </script>

    <script>
      (function () {
        const splash = document.getElementById('splash');
        if (!splash) return;

        if (sessionStorage.getItem('lomiSplashShown') === '1') {
          splash.remove();
          return;
        }

        const ANIM_DURATION = 6200; // start fade-out slightly before animation fully completes

        setTimeout(() => {
          splash.classList.add('hidden');
          splash.addEventListener('transitionend', () => splash.remove(), { once: true });
        }, ANIM_DURATION);

        sessionStorage.setItem('lomiSplashShown', '1');
      })();
    </script>
  </body>
</html>
