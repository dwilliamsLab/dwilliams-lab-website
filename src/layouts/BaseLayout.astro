---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Laboratory of Oral Mucosal Immunity',
  description = 'Website for the Laboratory of Oral Mucosal Immunity at the University of Minnesota',
  ogImage = '/images/share.png',
} = Astro.props;

const siteName = 'Laboratory of Oral Mucosal Immunity';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, 'https://williams.science').toString();
const ogImageURL = new URL(ogImage, 'https://williams.science').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-VETJQ1T7RM">
    </script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VETJQ1T7RM');
    </script>

    <!-- Fonts: Instrument Serif (display) + Work Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@300..700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon & app icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <script
      async
      src="https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js"
    ></script>

    <script
      async
      src="https://integration-badge.dimensions.ai/static/ai/badge.js"
      charset="utf-8"
    ></script>

    <!-- Prevent splash flash after first view -->
    <script>
      (function () {
        try {
          if (window.sessionStorage && window.sessionStorage.getItem('lomiSplashShown') === '1') {
            document.documentElement.classList.add('lomi-no-splash');
          }
        } catch (e) {
          // ignore
        }
      })();
    </script>

    <!-- Splash overlay styles + header logo overrides -->
    <style>
      #splash {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background-color: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          opacity 1.2s ease,
          backdrop-filter 1.2s ease,
          background-color 1.2s ease;
      }

      #splash.hidden {
        opacity: 0;
        pointer-events: none;
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        background-color: rgba(255, 255, 255, 0);
      }

      /* If splash already shown in this session, never display it */
      .lomi-no-splash #splash {
        display: none !important;
      }

      #splash-logo {
        width: min(500px, 80vw);
      }

      /* Header logo: icon + text in a row */
      .site-logo {
        flex-direction: row;
        align-items: center;
        gap: 0.85rem;
      }

      .logo-mark {
        width: 40px;
        height: 40px;
        flex-shrink: 0;
      }

      .logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
      }

      @media (max-width: 640px) {
        .logo-mark {
          width: 32px;
          height: 32px;
        }
      }
    </style>
  </head>
  <body>
    <!-- One-time animated splash overlay -->
