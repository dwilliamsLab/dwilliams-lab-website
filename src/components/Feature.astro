---
/**
 * Feature.astro
 * Replaces _includes/feature.html
 * Renders a section with an image on one side and text on the other.
 */
interface Props {
  image: string;
  imageAlt?: string;
  headline?: string;
  flip?: boolean; // flip image to right side
}

const { image, imageAlt = '', headline, flip = false } = Astro.props;
---

<div class:list={['feature', { 'feature--flipped': flip }]}>
  {image && (
    <div class="feature-image">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class="feature-body">
    {headline && <h3 class="feature-headline">{headline}</h3>}
    <div class="feature-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .feature--flipped .feature-image { order: 2; }
  .feature--flipped .feature-body  { order: 1; }

  .feature-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .feature-headline {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .feature-content {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .feature {
      grid-template-columns: 1fr;
    }
    .feature--flipped .feature-image { order: 0; }
    .feature--flipped .feature-body  { order: 0; }
  }
</style>
